PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/online-assignment-system

# JWT
JWT_SECRET=your_super_secret_key
JWT_EXPIRE=7d

# Environment
NODE_ENV=development

# Email Configuration (Forgot Password OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Code Execution — Judge0 CE via RapidAPI (optional, falls back to public Piston)
# Get credentials from https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Piston API (used when Judge0 credentials are not set)
PISTON_API_URL=https://emkc.org/api/v2/piston

# Client URL (CORS)
CLIENT_URL=http://localhost:5173
